# 复制此文件为 .env 并填入实际值（仅用于本地开发）
# Vercel 部署时，请在 Vercel 控制台的 Environment Variables 中配置这些变量

# Flask 密钥（生产环境请使用强随机字符串）
SECRET_KEY=your-secret-key-here

# DeepSeek API Key
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 云数据库连接字符串（Vercel 上必须配置）
# 推荐使用 Neon（https://neon.tech）免费 PostgreSQL
# 格式：postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
